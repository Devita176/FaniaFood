<?php
session_start();
require_once '../config/koneksi.php';
if (!isset($_SESSION['user']) || $_SESSION['user']['role'] !== 'kepala') { header('Location: ../auth/login.php'); exit; }

$user    = $_SESSION['user'];
$success = ''; $error = '';

// Simpan catatan laporan
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $periode  = trim($_POST['periode']);
    $catatan  = trim($_POST['catatan']);

    // Hitung otomatis dari DB
    [$bulan, $tahun] = explode('-', $periode);
    $total_pesanan   = $conn->query("SELECT COUNT(*) as c FROM pesanan WHERE MONTH(created_at)=$bulan AND YEAR(created_at)=$tahun")->fetch_assoc()['c'];
    $total_pendapatan = $conn->query("SELECT SUM(p.total_harga) as t FROM transaksi t JOIN pesanan p ON t.id_pesanan=p.id_pesanan WHERE t.status_bayar='lunas' AND MONTH(p.created_at)=$bulan AND YEAR(p.created_at)=$tahun")->fetch_assoc()['t'] ?? 0;

    $periode_label = date('F Y', mktime(0,0,0,$bulan,1,$tahun));
    $stmt = $conn->prepare("INSERT INTO laporan (periode, total_pesanan, total_pendapatan, catatan) VALUES (?, ?, ?, ?)");
    $stmt->bind_param('sids', $periode_label, $total_pesanan, $total_pendapatan, $catatan);
    if ($stmt->execute()) $success = 'Laporan berhasil disimpan!';
    else $error = 'Gagal menyimpan laporan.';
}

// Ambil semua laporan
$laporan = $conn->query("SELECT * FROM laporan ORDER BY created_at DESC");

// Data untuk tabel rekap pesanan bulanan
$rekap = $conn->query("SELECT DATE_FORMAT(created_at,'%M %Y') as bulan, MONTH(created_at) as bln, YEAR(created_at) as thn,
    COUNT(*) as total_pesanan,
    SUM(CASE WHEN status='selesai' THEN 1 ELSE 0 END) as selesai,
    SUM(total_harga) as pendapatan
    FROM pesanan GROUP BY YEAR(created_at), MONTH(created_at) ORDER BY thn DESC, bln DESC");
?>
